{
  "type": "module",
  "name": "@rvoh/dream",
  "version": "2.15.1",
  "description": "dream orm",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rvohealth/dream.git"
  },
  "author": "RVOHealth",
  "license": "MIT",
  "main": "./dist/cjs/src/package-exports/index.js",
  "module": "./dist/esm/src/package-exports/index.js",
  "types": "./dist/types/src/package-exports/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/src/package-exports/index.d.ts",
      "import": "./dist/esm/src/package-exports/index.js",
      "require": "./dist/cjs/src/package-exports/index.js"
    },
    "./db": {
      "types": "./dist/types/src/package-exports/db.d.ts",
      "import": "./dist/esm/src/package-exports/db.js",
      "require": "./dist/cjs/src/package-exports/db.js"
    },
    "./errors": {
      "types": "./dist/types/src/package-exports/errors.d.ts",
      "import": "./dist/esm/src/package-exports/errors.js",
      "require": "./dist/cjs/src/package-exports/errors.js"
    },
    "./system": {
      "types": "./dist/types/src/package-exports/system.d.ts",
      "import": "./dist/esm/src/package-exports/system.js",
      "require": "./dist/cjs/src/package-exports/system.js"
    },
    "./openapi": {
      "types": "./dist/types/src/package-exports/openapi.d.ts",
      "import": "./dist/esm/src/package-exports/openapi.js",
      "require": "./dist/cjs/src/package-exports/openapi.js"
    },
    "./types": {
      "types": "./dist/types/src/package-exports/types.d.ts",
      "import": "./dist/esm/src/package-exports/types.js",
      "require": "./dist/cjs/src/package-exports/types.js"
    },
    "./utils": {
      "types": "./dist/types/src/package-exports/utils.d.ts",
      "import": "./dist/esm/src/package-exports/utils.js",
      "require": "./dist/cjs/src/package-exports/utils.js"
    }
  },
  "files": [
    "dist/**/*",
    "docs/**/*"
  ],
  "scripts": {
    "dream": "DREAM_CORE_DEVELOPMENT=1 pnpm dreamts",
    "dream:js": "node --experimental-modules dist/test-app/cli/index.js",
    "dreamts": "NODE_ENV=${NODE_ENV:-test} tsx ./test-app/cli/index.ts",
    "build": "echo \"building cjs...\" && rm -rf dist && pnpm tsc -p ./tsconfig.cjs.build.json && echo \"building esm...\" && pnpm tsc -p ./tsconfig.esm.build.json && cp -r src/types/ dist/types/src/types/",
    "build:test-app": "rm -rf dist && echo \"building test app to esm...\" && pnpm tsc -p ./tsconfig.esm.build.test-app.json && echo \"building test app to cjs...\" && pnpm tsc -p ./tsconfig.cjs.build.test-app.json",
    "spec": "DREAM_CORE_DEVELOPMENT=1 pnpm dream db:integrity-check && DREAM_CORE_DEVELOPMENT=1 DREAM_CORE_SPEC_RUN=1 vitest",
    "console": "DREAM_CORE_DEVELOPMENT=1 pnpm dream db:integrity-check && NODE_ENV=${NODE_ENV:-test} DREAM_CORE_DEVELOPMENT=1 tsx ./test-app/app/conf/repl.ts",
    "types:cjs:trace": "rm -rf dist && pnpm tsc -p ./tsconfig.cjs.build.json --generateTrace ./typetrace --diagnostics && pnpm analyze-trace ./typetrace --skipMillis 100 --forceMillis 300",
    "types:esm:trace": "rm -rf dist && pnpm tsc -p ./tsconfig.esm.build.json --generateTrace ./typetrace --diagnostics && pnpm analyze-trace ./typetrace --skipMillis 100 --forceMillis 300",
    "types:cjs:trace-test-app": "rm -rf dist && pnpm tsc -p ./tsconfig.cjs.trace.json --generateTrace ./typetrace --diagnostics && pnpm analyze-trace ./typetrace --skipMillis 100 --forceMillis 300",
    "types:esm:trace-test-app": "rm -rf dist && pnpm tsc -p ./tsconfig.esm.trace.json --generateTrace ./typetrace --diagnostics && pnpm analyze-trace ./typetrace --skipMillis 100 --forceMillis 300",
    "format": "pnpm prettier . --write",
    "lint": "pnpm eslint --no-warn-ignored \"src/**/*.ts\" \"spec/**/*.ts\" \"test-app/**/*.ts\" && pnpm prettier . --check",
    "prepack": "pnpm build && pnpm dream build:docs"
  },
  "dependencies": {
    "colorette": "^2.0.20",
    "dotenv": "^17.2.3",
    "luxon": "^3.7.2",
    "yoctocolors": "^2.1.1"
  },
  "peerDependencies": {
    "@types/node": "*",
    "@types/pg": "*",
    "commander": "^14.0.3",
    "dotenv": "*",
    "kysely": "^0.29.0",
    "kysely-codegen": "~0.20.0",
    "pg": "*",
    "pluralize-esm": "^9.0.5",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "=9.0.0",
    "@rvoh/dream-spec-helpers": "^2.2.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/parser": "^8.57.1",
    "@typescript/analyze-trace": "^0.10.1",
    "commander": "^14.0.3",
    "eslint": "^9.0.0",
    "jest-extended": "^4.0.2",
    "kysely": "^0.29.0",
    "kysely-codegen": "~0.20.0",
    "mysql2": "^3.14.2",
    "pg": "^8.13.3",
    "pluralize-esm": "^9.0.5",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.5",
    "vitest": "^4.1.0",
    "winston": "^3.14.2"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
